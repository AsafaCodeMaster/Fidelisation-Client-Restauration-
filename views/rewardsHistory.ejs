<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Récompenses - FidélityApp</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/protected/home.css">
    <link rel="stylesheet" href="/css/protected/rewards.css">
</head>
<body>
    <!-- Include Sidebar Partial -->
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <main class="main-content" id="mainContent">
        <div class="rewards-container">
            <!-- Header -->
            <div class="page-header">
                <h1 class="page-title">
                    <i class="bi bi-trophy"></i>
                    Mes Récompenses
                </h1>
                <div class="points-badge">
                    <i class="bi bi-gem"></i>
                    <span id="userPoints">0</span> points
                </div>
            </div>

            <!-- Available Rewards Section -->
            <section class="rewards-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="bi bi-gift"></i>
                        Récompenses disponibles
                    </h2>
                </div>

                <div class="rewards-grid" id="availableRewards">
                    <!-- Dynamic content -->
                </div>

                <div class="empty-state" id="emptyAvailable" style="display: none;">
                    <i class="bi bi-inbox"></i>
                    <p>Aucune récompense disponible pour le moment</p>
                </div>
            </section>

            <!-- History Section -->
            <section class="history-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Historique des récompenses
                    </h2>
                </div>

                <div class="history-list" id="rewardsHistory">
                    <!-- Dynamic content -->
                </div>

                <div class="empty-state" id="emptyHistory" style="display: none;">
                    <i class="bi bi-inbox"></i>
                    <p>Aucun historique de récompenses</p>
                </div>
            </section>
        </div>
    </main>

    <!-- Claim Modal -->
    <div id="claimModal" class="modal" style="display: none;">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3>Récupérer la récompense</h3>
                <button class="modal-close" onclick="closeClaimModal()">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Content dynamically inserted -->
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeClaimModal()">Annuler</button>
                <button class="btn-confirm" id="confirmClaimBtn">Confirmer</button>
            </div>
        </div>
    </div>

    <script src="/js/protected/home.js"></script>
    <script src="/js/protected/rewards.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Mon Application</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-red: #dc2626;
            --dark-bg: #1a1a1a;
            --darker-bg: #0f0f0f;
            --sidebar-width: 260px;
            --sidebar-collapsed: 80px;
            --text-white: #ffffff;
            --text-gray: #9ca3af;
            --hover-bg: #2a2a2a;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 100%);
            color: var(--text-white);
            min-height: 100vh;
        }

        /* Sidebar Styles */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            width: var(--sidebar-width);
            background: var(--dark-bg);
            border-right: 1px solid rgba(220, 38, 38, 0.2);
            padding: 1.5rem 0;
            transition: var(--transition);
            z-index: 1000;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
        }

        .sidebar.collapsed {
            width: var(--sidebar-collapsed);
        }

        .sidebar-header {
            padding: 0 1.5rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transition: var(--transition);
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: var(--primary-red);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .logo-text {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-white);
            white-space: nowrap;
            transition: var(--transition);
        }

        .sidebar.collapsed .logo-text {
            opacity: 0;
            width: 0;
        }

        .toggle-btn {
            width: 36px;
            height: 36px;
            background: var(--hover-bg);
            border: none;
            border-radius: 8px;
            color: var(--text-white);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            flex-shrink: 0;
        }

        .toggle-btn:hover {
            background: var(--primary-red);
            transform: scale(1.05);
        }

        .sidebar.collapsed .toggle-btn {
            margin: 0 auto;
        }

        /* Navigation */
        .nav-menu {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
        }

        .nav-menu::-webkit-scrollbar {
            width: 4px;
        }

        .nav-menu::-webkit-scrollbar-thumb {
            background: var(--primary-red);
            border-radius: 4px;
        }

        .nav-section {
            margin-bottom: 1.5rem;
        }

        .nav-section-title {
            padding: 0 1.5rem;
            margin-bottom: 0.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-gray);
            transition: var(--transition);
        }

        .sidebar.collapsed .nav-section-title {
            opacity: 0;
            height: 0;
            padding: 0;
            margin: 0;
        }

        .nav-item {
            list-style: none;
        }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            color: var(--text-gray);
            text-decoration: none;
            transition: var(--transition);
            position: relative;
            gap: 1rem;
        }

        .nav-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 3px;
            background: var(--primary-red);
            transform: scaleY(0);
            transition: var(--transition);
        }

        .nav-link:hover {
            background: var(--hover-bg);
            color: var(--text-white);
        }

        .nav-link:hover::before {
            transform: scaleY(1);
        }

        .nav-link.active {
            background: linear-gradient(90deg, rgba(220, 38, 38, 0.2) 0%, transparent 100%);
            color: var(--text-white);
        }

        .nav-link.active::before {
            transform: scaleY(1);
        }

        .nav-link.active .nav-icon {
            color: var(--primary-red);
        }

        .nav-icon {
            font-size: 1.25rem;
            flex-shrink: 0;
            transition: var(--transition);
        }

        .nav-text {
            white-space: nowrap;
            transition: var(--transition);
        }

        .sidebar.collapsed .nav-text {
            opacity: 0;
            width: 0;
        }

        .badge {
            background: var(--primary-red);
            color: var(--text-white);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.125rem 0.5rem;
            border-radius: 12px;
            margin-left: auto;
            transition: var(--transition);
        }

        .sidebar.collapsed .badge {
            opacity: 0;
            width: 0;
        }

        /* Theme Switch */
        .theme-switch {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            margin: 0.5rem 1rem;
            background: var(--hover-bg);
            border-radius: 12px;
            gap: 1rem;
            transition: var(--transition);
        }

        .theme-toggle {
            position: relative;
            width: 48px;
            height: 24px;
            background: var(--darker-bg);
            border-radius: 12px;
            cursor: pointer;
            transition: var(--transition);
            flex-shrink: 0;
        }

        .theme-toggle::before {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--text-white);
            top: 3px;
            left: 3px;
            transition: var(--transition);
        }

        .theme-toggle.active {
            background: var(--primary-red);
        }

        .theme-toggle.active::before {
            transform: translateX(24px);
        }

        .theme-label {
            font-size: 0.875rem;
            color: var(--text-gray);
            white-space: nowrap;
            transition: var(--transition);
        }

        .sidebar.collapsed .theme-label {
            opacity: 0;
            width: 0;
        }

        /* User Profile */
        .user-profile {
            padding: 1rem 1.5rem;
            margin-top: auto;
            border-top: 1px solid rgba(220, 38, 38, 0.2);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transition: var(--transition);
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-red) 0%, #991b1b 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            flex-shrink: 0;
        }

        .user-details {
            flex: 1;
            overflow: hidden;
            transition: var(--transition);
        }

        .user-name {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-white);
            white-space: nowrap;
        }

        .user-email {
            font-size: 0.75rem;
            color: var(--text-gray);
            white-space: nowrap;
        }

        .sidebar.collapsed .user-details {
            opacity: 0;
            width: 0;
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 2rem;
            transition: var(--transition);
            min-height: 100vh;
        }

        .main-content.expanded {
            margin-left: var(--sidebar-collapsed);
        }

        .content-header {
            margin-bottom: 2rem;
        }

        .content-header h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--text-white) 0%, var(--text-gray) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .content-header p {
            color: var(--text-gray);
        }

        /* Cards */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .card {
            background: var(--dark-bg);
            border: 1px solid rgba(220, 38, 38, 0.2);
            border-radius: 16px;
            padding: 1.5rem;
            transition: var(--transition);
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(220, 38, 38, 0.2);
            border-color: var(--primary-red);
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 0.875rem;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .card-icon {
            width: 40px;
            height: 40px;
            background: rgba(220, 38, 38, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-red);
            font-size: 1.25rem;
        }

        .card-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-white);
            margin-bottom: 0.5rem;
        }

        .card-description {
            font-size: 0.875rem;
            color: var(--text-gray);
        }

        .card-trend {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.875rem;
            color: #10b981;
            margin-top: 0.5rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.mobile-open {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
            }

            .mobile-menu-btn {
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                width: 56px;
                height: 56px;
                background: var(--primary-red);
                border: none;
                border-radius: 50%;
                color: var(--text-white);
                font-size: 1.5rem;
                cursor: pointer;
                box-shadow: 0 10px 30px rgba(220, 38, 38, 0.4);
                z-index: 999;
                display: flex;
                align-items: center;
                justify-content: center;
            }
        }

        @media (min-width: 769px) {
            .mobile-menu-btn {
                display: none;
            }
        }

        /* Light Theme */
        body.light-theme {
            background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
            color: #1f2937;
        }

        body.light-theme .sidebar {
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
        }

        body.light-theme .toggle-btn {
            background: #f3f4f6;
            color: #1f2937;
        }

        body.light-theme .toggle-btn:hover {
            background: var(--primary-red);
            color: white;
        }

        body.light-theme .nav-link {
            color: #6b7280;
        }

        body.light-theme .nav-link:hover {
            background: #f3f4f6;
            color: #1f2937;
        }

        body.light-theme .nav-link.active {
            background: linear-gradient(90deg, rgba(220, 38, 38, 0.1) 0%, transparent 100%);
            color: #1f2937;
        }

        body.light-theme .theme-switch {
            background: #f3f4f6;
        }

        body.light-theme .theme-toggle {
            background: #e5e7eb;
        }

        body.light-theme .user-profile {
            border-top: 1px solid #e5e7eb;
        }

        body.light-theme .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
        }

        body.light-theme .card:hover {
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        body.light-theme .content-header h1 {
            background: linear-gradient(135deg, #1f2937 0%, #6b7280 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        body.light-theme .logo-text,
        body.light-theme .user-name,
        body.light-theme .card-value {
            color: #1f2937;
        }

        body.light-theme .nav-section-title,
        body.light-theme .theme-label,
        body.light-theme .user-email,
        body.light-theme .card-title,
        body.light-theme .card-description,
        body.light-theme .content-header p {
            color: #6b7280;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <!-- Header -->
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <span class="logo-text">MyApp</span>
            </div>
            <button class="toggle-btn" id="toggleBtn">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <!-- Navigation Menu -->
        <nav class="nav-menu">
            <div class="nav-section">
                <h3 class="nav-section-title">Menu Principal</h3>
                <ul>
                    <li class="nav-item">
                        <a href="#" class="nav-link active">
                            <i class="bi bi-house-door-fill nav-icon"></i>
                            <span class="nav-text">Home</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="bi bi-gem nav-icon"></i>
                            <span class="nav-text">Points</span>
                            <span class="badge">1,234</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="bi bi-clock-history nav-icon"></i>
                            <span class="nav-text">Purchase History</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="bi bi-person-circle nav-icon"></i>
                            <span class="nav-text">Profile</span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="nav-section">
                <h3 class="nav-section-title">Paramètres</h3>
                <ul>
                    <li class="nav-item">
                        <a href="#" class="nav-link" id="logoutBtn">
                            <i class="bi bi-box-arrow-right nav-icon"></i>
                            <span class="nav-text">Logout</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Theme Switch -->
        <div class="theme-switch">
            <div class="theme-toggle" id="themeToggle">
            </div>
            <span class="theme-label">Dark Mode</span>
        </div>

        <!-- User Profile -->
        <div class="user-profile">
            <div class="user-info">
                <div class="user-avatar">JD</div>
                <div class="user-details">
                    <div class="user-name">John Doe</div>
                    <div class="user-email">john@example.com</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" id="mobileMenuBtn">
        <i class="bi bi-list"></i>
    </button>

    <!-- Main Content -->
    <main class="main-content" id="mainContent">
        <div class="content-header">
            <h1>Welcome Back, John!</h1>
            <p>Here's what's happening with your account today.</p>
        </div>

        <!-- Cards Grid -->
        <div class="cards-grid">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Total Points</span>
                    <div class="card-icon">
                        <i class="bi bi-gem"></i>
                    </div>
                </div>
                <div class="card-value">1,234</div>
                <div class="card-description">Available for redemption</div>
                <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>+12% from last month</span>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Recent Purchases</span>
                    <div class="card-icon">
                        <i class="bi bi-cart-check"></i>
                    </div>
                </div>
                <div class="card-value">24</div>
                <div class="card-description">This month</div>
                <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>+8% from last month</span>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Total Spent</span>
                    <div class="card-icon">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
                <div class="card-value">$3,456</div>
                <div class="card-description">All time</div>
                <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>+15% from last month</span>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Rewards Earned</span>
                    <div class="card-icon">
                        <i class="bi bi-trophy"></i>
                    </div>
                </div>
                <div class="card-value">8</div>
                <div class="card-description">Achievements unlocked</div>
                <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>+3 this week</span>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Toggle Sidebar
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('toggleBtn');
        const mainContent = document.getElementById('mainContent');
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');

        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        });

        // Mobile menu
        if (mobileMenuBtn) {
            mobileMenuBtn.addEventListener('click', () => {
                sidebar.classList.toggle('mobile-open');
            });
        }

        // Theme Toggle
        const themeToggle = document.getElementById('themeToggle');
        const themeLabel = document.querySelector('.theme-label');
        const body = document.body;

        // Charger le thème sauvegardé
        const savedTheme = localStorage.getItem('theme') || 'dark';
        if (savedTheme === 'light') {
            body.classList.add('light-theme');
            themeToggle.classList.add('active');
            themeLabel.textContent = 'Light Mode';
        }

        themeToggle.addEventListener('click', () => {
            body.classList.toggle('light-theme');
            themeToggle.classList.toggle('active');
            
            const isLight = body.classList.contains('light-theme');
            themeLabel.textContent = isLight ? 'Light Mode' : 'Dark Mode';
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
        });

        // Navigation Active State
        const navLinks = document.querySelectorAll('.nav-link');
        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                if (link.id !== 'logoutBtn') {
                    e.preventDefault();
                    navLinks.forEach(l => l.classList.remove('active'));
                    link.classList.add('active');
                }
            });
        });

        // Logout
        const logoutBtn = document.getElementById('logoutBtn');
        logoutBtn.addEventListener('click', (e) => {
            e.preventDefault();
            if (confirm('Êtes-vous sûr de vouloir vous déconnecter ?')) {
                // Redirection vers la page de logout
                window.location.href = '/logout';
            }
        });

        // Fermer le menu mobile en cliquant à l'extérieur
        document.addEventListener('click', (e) => {
            if (window.innerWidth <= 768) {
                if (!sidebar.contains(e.target) && !mobileMenuBtn.contains(e.target)) {
                    sidebar.classList.remove('mobile-open');
                }
            }
        });

        // Animation au chargement
        window.addEventListener('load', () => {
            const cards = document.querySelectorAll('.card');
            cards.forEach((card, index) => {
                setTimeout(() => {
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    card.style.transition = 'all 0.5s ease';
                    
                    setTimeout(() => {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    }, 50);
                }, index * 100);
            });
        });
    </script>
</body>
</html>
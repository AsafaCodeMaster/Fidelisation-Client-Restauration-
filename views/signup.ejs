<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>S'inscrire - Programme de Fidélité</title>
  <link rel="stylesheet" href="./css/signup.css">

  <style>
    /* ===== Opt-in Code Verification Styling ===== */
    .verify-container {
      margin-top: 15px;
      text-align: center;
    }

    .code-box {
      position: relative;
      margin: 15px auto;
      display: flex;
      justify-content: center;
      gap: 10px;
      width: fit-content;
    }

    .box {
      width: 45px;
      height: 55px;
      border: 2px solid #aaa;
      border-radius: 8px;
      font-size: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #fff;
      color: #333;
      transition: all 0.2s;
    }

    .box.active {
      border-color: #007bff;
      box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
    }

    .hidden-code-input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
  </style>
</head>
<body class="light-theme">
  <!-- Navigation -->
  <nav>
    <div class="nav-left">
      <a href="/" class="logo">
                <img src="/img/gastrologo.png" alt="" srcset="" class="logo-placeholder">
      </a>
      <button class="theme-toggle" onclick="toggleTheme()" title="Changer le thème">
        <span id="theme-icon">🌙</span>
      </button>
    </div>
    <div class="nav-links">
      <a href="/login">Se connecter</a>
      <a href="/signup" class="active">S'inscrire</a>
    </div>
  </nav>

  <div class="container">
    <!-- Section Formulaire -->
    <div class="form-section">
      <div class="form-wrapper">
        <h1 class="form-title">S'inscrire</h1>
                
    <% if (!optin){ %> <form id="signupForm" action="/optinVerify" method="POST"> <% } %>
    <% if (optin){ %> <form id="signupForm" action="/signup" method="POST"> <% } %>

          <div class="form-group">
            <label class="field-label">Nom<span class="required-mark">*</span></label>
            <div class="input-wrapper">
              <span class="input-icon">👤</span>
              <input type="text" name="nom" placeholder="Nom" onkeyup="onNothing()" <% if (optin) { %> value="<%= rname %>" disabled <% } %> required>
            </div>
          </div>

          <div class="form-group">
            <label class="field-label">Prénom<span class="required-mark">*</span></label>
            <div class="input-wrapper">
              <span class="input-icon">👤</span>
              <input type="text" name="prenom" placeholder="Prénom" onkeyup="onNothing()" <% if (optin) { %> value="<%= rfirstname %>" disabled <% } %> required>
            </div>
          </div>

          <div class="form-group">
            <label class="field-label">Numéro ou Email<span class="required-mark">*</span></label>
            <div class="input-wrapper">
              <span class="input-icon">📧</span>
              <input type="text" name="contact" placeholder="Numéro ou Email" id="contactInput" onkeyup="validateContact()" <% if (optin) { %> value="<%= rcontact %>" disabled <% } %> required>
            </div>
            <p style="color:rgb(180, 0, 0);" id="contactError" class="hiddenContactError">numero à 10 chiffres ou email valide</p>
          </div>
          <% if (!optin) { %>
          <div class="form-group">
            <label class="field-label">Mot de passe<span class="required-mark">*</span></label>
            <div class="input-wrapper">
              <span class="input-icon">🔒</span>
              <input type="password" name="password" id="passwordInput" placeholder="Mot de passe" onkeyup="validatePassword()" required>
            </div>
            <div style="color:rgb(180, 0, 0);" id="passwordMessage"></div>
          </div>
          <% } %>
          <% if (optin) { %>
          <div class="verify-container">
            <label for="code">code de vérification à votre email</label>
            <div class="code-box" id="codeBox">
              <div class="box active"></div>
              <div class="box"></div>
              <div class="box"></div>
              <div class="box"></div>
              <div class="box"></div>
              <div class="box"></div>
              <input type="text" name="optinCode" maxlength="6" name="code" id="hiddenCodeInput" class="hidden-code-input" autofocus>
            </div>
          </div>
          <% } %>

          <button type="submit" id="submitButton" class="submit-btn" >S'INSCRIRE</button>
        </form>

        <div class="switch-form">
          Vous avez déjà un compte ?
          <a href="/login">Se connecter</a>
        </div>
      </div>
    </div>

    <!-- Section Branding -->
    <div class="brand-section">
      <div class="brand-content">
        <div class="brand-welcome">Bienvenue dans notre</div>
        <div class="brand-logo"><span class="brand-logo-icon">🍕</span></div>
        <h2 class="brand-name">Programme<br>de Fidélité</h2>
        <p class="brand-tagline">
          Rejoignez notre programme et profitez d'avantages exclusifs à chaque commande
        </p>
      </div>
      <div class="brand-footer">© 2025 Gastronomie Pizza</div>
    </div>
  </div>

  <script src="./js/ThemeHandler.js"></script>
  <script src="./js/signup.js"></script>

  <% if (optin) { %>
  <script>
    // ===== Verification Input Logic =====
    const input = document.getElementById("hiddenCodeInput");
    const boxes = document.querySelectorAll(".box");

    input.addEventListener("input", () => {
      const value = input.value.replace(/\D/g, "").slice(0, 6);
      input.value = value;
      boxes.forEach((box, index) => {
        box.textContent = value[index] || "";
        box.classList.toggle("active", index === value.length);
      });
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace") {
        boxes.forEach((box, index) => {
          if (index >= input.value.length - 1) {
            box.textContent = "";
          }
        });
      }
    });

    document.getElementById("codeBox").addEventListener("click", () => input.focus());
  </script>
  <% } %>
</body>
</html>

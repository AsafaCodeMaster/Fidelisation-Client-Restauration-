<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>La Gastronomie Pizza</title>
    <link rel="stylesheet" href="/css/index.css">
   
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="nav-left">
            <div class="logo">
                <img src="/img/gastrologo.png" alt="" srcset="" class="logo-placeholder">
<!--                 <span class=LOGO</span> -->
            </div>
            <button class="theme-toggle" onclick="toggleTheme()" title="Changer le thème">
                <span id="theme-icon">☀️</span>
            </button>
        </div>
        <div class="nav-links">
            <a href="/login">Login</a>
            <a href="/signup">Sign Up</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <div class="welcome-prefix">Bienvenue dans notre</div>
            <h1 class="main-title">PROGRAMME DE FIDÉLITÉ</h1>
            <p class="description">
                Rejoignez notre programme de fidélité et profitez d'avantages exclusifs à chaque commande. Accumulez des points, débloquez des récompenses et savourez des privilèges uniques.
            </p>
        </div>
    </section>

    <!-- Carrousel -->
    <div class="carousel">
        <!-- Slide 1 -->
        <div class="carousel-item active">
            <img src="/img/paneauPoints.png" alt="Pizza 1">
        </div>
        
        <!-- Slide 2 -->
        <div class="carousel-item">
            <img src="image2.jpg" alt="Pizza 2">
        </div>
        
        <!-- Slide 3 -->
        <div class="carousel-item">
            <img src="image3.jpg" alt="Pizza 3">
        </div>

        <!-- Indicateurs du carrousel -->
        <div class="carousel-indicators">
            <span class="indicator active" data-slide="0"></span>
            <span class="indicator" data-slide="1"></span>
            <span class="indicator" data-slide="2"></span>
        </div>
    </div>

    <!-- Section Fonctionnalités -->
    <section class="features-section">
        <!-- Feature 1 -->
        <div class="feature-block">
            <div class="feature-image">
                <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&h=600&fit=crop" alt="Gagner des points">
            </div>
            <div class="feature-content">
                <span class="feature-badge">Récompenses</span>
                <h2 class="feature-title">Gagnez des points à chaque commande</h2>
                <p class="feature-description">
                    Chaque achat vous rapporte des points de fidélité. Plus vous commandez, plus vous accumulez de points. Échangez-les contre des pizzas gratuites, des réductions exclusives et des offres spéciales réservées à nos membres fidèles.
                </p>
            </div>
        </div>

        <!-- Feature 2 -->
        <div class="feature-block reverse">
            <div class="feature-image">
                <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&h=600&fit=crop" alt="Offres exclusives">
            </div>
            <div class="feature-content">
                <span class="feature-badge">Avantages</span>
                <h2 class="feature-title">Accédez à des offres exclusives</h2>
                <p class="feature-description">
                    En tant que membre de notre programme de fidélité, bénéficiez d'offres spéciales et de promotions réservées uniquement à vous. Recevez des notifications sur les nouveaux produits, les événements spéciaux et les offres à durée limitée.
                </p>
            </div>
        </div>

        <!-- Feature 3 -->
        <div class="feature-block">
            <div class="feature-image">
                <img src="/img/paneauPoints.png" alt="Offres exclusives">
                <!-- <img src="https://images.unsplash.com/photo-1460306855393-0410f61241c7?w=800&h=600&fit=crop" alt="Suivi en temps réel"> -->
            </div>
            <div class="feature-content">
                <span class="feature-badge">Simplicité</span>
                <h2 class="feature-title">Suivez vos points en temps réel</h2>
                <p class="feature-description">
                    Notre plateforme intuitive vous permet de consulter votre solde de points, votre historique d'achats et vos récompenses disponibles à tout moment. Restez informé de votre progression et planifiez vos prochaines récompenses facilement.
                </p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2025 Programme de Fidélité Gastronomie Pizza. Tous droits réservés.</p>
    </footer>

    <script src="/js/index.js"></script>
    <script src="/js/ThemeHandler.js"></script>
</body>
</html>
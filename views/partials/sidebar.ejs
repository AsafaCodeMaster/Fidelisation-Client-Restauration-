                            <i class="bi bi-chat-left-text-fill nav-icon"></i>
                            <span class="nav-text">Feedback</span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="nav-section">
                <h3 class="nav-section-title">Paramètres</h3>
                <ul>
                    <li class="nav-item">
                        <form action="/logout" method="POST" id="logoutForm" style="margin: 0;">
                            <button type="submit" class="nav-link" id="logoutBtn" style="width: 100%; text-align: left; background: none; border: none; font-family: inherit; font-size: inherit;">
                                <i class="bi bi-box-arrow-right nav-icon"></i>
                                <span class="nav-text">Se déconnecter</span>
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Theme Switch -->
        <div class="theme-switch">
            <div class="theme-toggle" id="themeToggle">
            </div>
            <span class="theme-label">Dark Mode</span>
        </div>

        <!-- User Profile -->
        <div class="user-profile">
            <div class="user-info">
                <div class="user-avatar">{{JD}}</div>
                <div class="user-details">
                    <div class="user-name"><%= myclient.first_name %> <%= myclient.last_name %></div>
                    <div class="user-email">{{john@example.com}}</div>
                </div>
            </div>
        </div>
    </aside>
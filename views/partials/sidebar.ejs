                            <span class="nav-text">Home</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/points" class="nav-link">
                            <i class="bi bi-gem nav-icon"></i>
                            <span class="nav-text">Points</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/orders" class="nav-link">
                            <i class="bi bi-bag-check-fill nav-icon"></i>
                            <span class="nav-text">Commander</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/purchase-history" class="nav-link">
                            <i class="bi bi-clock-history nav-icon"></i>
                            <span class="nav-text">Historique d'achats</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/rewards-history" class="nav-link">
                            <i class="bi bi-trophy-fill nav-icon"></i>
                            <span class="nav-text">Historique de récompenses</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile" class="nav-link">
                            <i class="bi bi-person-circle nav-icon"></i>
                            <span class="nav-text">Profil</span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="nav-section">
                <h3 class="nav-section-title">Support</h3>
                <ul>

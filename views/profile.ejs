<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - FidélityApp</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/protected/home.css">
    <link rel="stylesheet" href="/css/protected/profile.css">
    <!-- Sidebar CSS (déjà inclus dans votre partial) -->
    
 
</head>
<body>
    <!-- Include Sidebar Partial -->
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <main class="main-content expanded" id="mainContent">
        <div class="profile-container">
            <!-- Alert Messages -->
            <div id="alertContainer"></div>

            <!-- Profile Header -->
            <div class="profile-header">
                <div class="profile-header-content">
                    <div class="profile-avatar-large">
                        <span id="avatarInitials"></span>
                        <div class="avatar-upload-btn" title="Changer l'avatar">
                            <i class="bi bi-camera-fill"></i>
                        </div>
                    </div>
                    <div class="profile-header-info">
                        <h1 id="displayName"></h1>
                        <p id="displayEmail"></p>
                        <div class="profile-stats">
                            <div class="stat-item">
                                <div id="clientPoints" class="stat-value"></div>
                                <div class="stat-label">Points</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value" id="totalPurchase"></div>
                                <div class="stat-label">Achats</div>
                            </div>
                            <div class="stat-item">
                                <div id="clientRank" class="stat-value"></div>
                                <div class="stat-label">Statut</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Personal Information Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title">
                        <div class="section-icon">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <span>Informations Personnelles</span>
                    </div>
                    <div class="edit-mode-toggle">
                        <span style="color: var(--text-gray); font-size: 0.875rem;">Mode édition</span>
                        <div class="toggle-switch" id="editToggle"></div>
                    </div>
                </div>

                <form id="profileForm">
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                Nom <span class="required">*</span>
                            </label>
                            <div class="input-group">
                                <i class="bi bi-person input-icon"></i>
                                <input type="text" class="form-input" id="nom" name="nom" disabled required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Prénom <span class="required">*</span>
                            </label>
                            <div class="input-group">
                                <i class="bi bi-person input-icon"></i>
                                <input type="text" class="form-input" id="prenom" name="prenom" disabled required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Email <span class="required">*</span>
                            </label>
                            <div class="input-group">
                                <i class="bi bi-envelope input-icon"></i>
                                <input type="email" class="form-input" id="email" name="email" disabled >
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Numéro de téléphone
                            </label>
                            <div class="input-group">
                                <i class="bi bi-telephone input-icon"></i>
                                <input type="tel" class="form-input" id="numero" name="numero"  disabled >
                            </div>
                        </div>

                        <div class="form-group full-width">
                            <label class="form-label">
                                Adresse
                            </label>
                            <div class="input-group">
                                <i class="bi bi-geo-alt input-icon"></i>
                                <input type="text" class="form-input" id="adresse" name="adresse"  disabled>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Ville
                            </label>
                            <div class="input-group">
                                <i class="bi bi-building input-icon"></i>
                                <input type="text" class="form-input" id="ville" name="ville" 
                                       placeholder="Paris" value="" disabled>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Date de naissance
                            </label>
                            <div class="input-group">
                                <i class="bi bi-calendar input-icon"></i>
                                <input type="date" class="form-input" id="dateNaissance" name="dateNaissance" 
                                       value="" disabled>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Genre
                            </label>
                            <select class="form-select" id="genre" name="genre" disabled>
                                <option value="">Sélectionner...</option>
                                <option value="homme">Homme</option>
                                <option value="femme">Femme</option>
                                <option value="autre">Autre</option>
                            </select>
                        </div>
                    </div>

                    <div class="btn-group" id="formActions" style="display: block;">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i>
                            Sauvegarder les modifications
                        </button>
                        <button type="button" class="btn btn-secondary" id="cancelBtn">
                            <i class="bi bi-x-circle"></i>
                            Annuler
                        </button>
                    </div>
                </form>
            </div>

            <!-- Security Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title">
                        <div class="section-icon">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <span>Sécurité</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Mot de passe</label>
                    <p style="color: var(--text-gray); font-size: 0.875rem; margin-bottom: 1rem;">
                        Dernière modification : <span id="lastTimePasswordChanged"></span>
                    </p>
                    <a href="/change-password" class="btn btn-primary">
                        <i class="bi bi-key-fill"></i>
                        Changer le mot de passe
                    </a>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title">
                        <div class="section-icon" style="background: rgba(239, 68, 68, 0.2); color: var(--danger-red);">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <span style="color: var(--danger-red);">Zone Dangereuse</span>
                    </div>
                </div>

                <div class="danger-zone">
                    <div class="danger-zone-header">
                        <i class="bi bi-trash-fill" style="font-size: 1.5rem; color: var(--danger-red);"></i>
                        <div class="danger-zone-title">Supprimer le compte</div>
                    </div>
                    <p class="danger-zone-description">
                        Une fois votre compte supprimé, toutes vos données seront définitivement effacées. 
                        Cette action est irréversible et vous perdrez tous vos points et historiques.
                    </p>
                    <button type="button" class="btn btn-danger" id="deleteAccountBtn">
                        <i class="bi bi-trash"></i>
                        Supprimer mon compte
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal" style="display: none;">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3>Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous absolument sûr de vouloir supprimer votre compte ?</p>
                <p style="color: var(--danger-red); font-weight: 600;">
                    Cette action est IRRÉVERSIBLE et entraînera :
                </p>
                <ul style="color: var(--text-gray);">
                    <li>La perte définitive de tous vos points (1,234 points)</li>
                    <li>La suppression de tout votre historique d'achats</li>
                    <li>La suppression de toutes vos récompenses</li>
                    <li>La fermeture immédiate de votre compte</li>
                </ul>
                <div class="form-group" style="margin-top: 1.5rem;">
                    <label class="form-label">
                        Tapez "SUPPRIMER" pour confirmer <span class="required">*</span>
                    </label>
                    <input type="text" class="form-input" id="confirmDeleteInput" placeholder="SUPPRIMER">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="cancelDeleteBtn">Annuler</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn" >
                    <i class="bi bi-trash"></i>
                    Supprimer définitivement
                </button>
            </div>
        </div>
    </div>

    <style>
        /* Modal Styles */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-backdrop {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(4px);
        }

        .modal-content {
            position: relative;
            background: var(--dark-bg);
            border: 1px solid rgba(220, 38, 38, 0.3);
            border-radius: 16px;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            z-index: 1;
        }

        .modal-header {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(220, 38, 38, 0.2);
        }

        .modal-header h3 {
            margin: 0;
            color: var(--text-white);
            font-size: 1.25rem;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-body p {
            color: var(--text-gray);
            margin-bottom: 1rem;
        }

        .modal-body ul {
            padding-left: 1.5rem;
            margin-bottom: 0;
        }

        .modal-body li {
            margin-bottom: 0.5rem;
        }

        .modal-footer {
            padding: 1.5rem;
            border-top: 1px solid rgba(220, 38, 38, 0.2);
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
        }

        body.light-theme .modal-content {
            background: #ffffff;
            border: 1px solid #e5e7eb;
        }

        body.light-theme .modal-header,
        body.light-theme .modal-footer {
            border-color: #e5e7eb;
        }

        body.light-theme .modal-header h3 {
            color: #1f2937;
        }
    </style>

    <script src="/js/protected/profile.js"></script>
    <script src="/js/protected/home.js"></script>
    </body>
    </html>
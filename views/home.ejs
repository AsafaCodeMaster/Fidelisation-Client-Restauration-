<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/protected/home.css">
</head>
<body>
    <!-- Sidebar -->
     <%- include('partials/sidebar') %>
     

    <!-- Main Content -->
    <main class="main-content" id="mainContent">
        <div class="content-header">
            <h1>Content de vous revoir, <span id="names"></span></h1>
            <p>Voici le dernier résumé de vos achats</p>
        </div>

        <!-- Cards Grid -->
        <div class="cards-grid">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Points Totaux</span>
                    <div class="card-icon">
                        <i class="bi bi-gem"></i>
                    </div>
                </div>
                <div class="card-value" id="points"></div>
                <div class="card-description">Utilisez vos Points pour les recompenses disponibles</div>
<!--                 <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>{{+12%}} from last month</span>
                </div> -->
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Nombres D'achats</span>
                    <div class="card-icon">
                        <i class="bi bi-cart-check"></i>
                    </div>
                </div>
                <div class="card-value" id="totalPurchase"></div>
                <div class="card-description">This month</div>
               <!--  <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>{{+8%}} from last month</span>
                </div> -->
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Montant dépensé</span>
                    <div class="card-icon">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
                <div class="card-value" id="totalSpent"></div>
<!--                 <div class="card-description">All time</div> -->
<!--                 <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>{{+15%}} from last month</span>
                
                </div> -->
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Récompenses récupérés</span>
                    <div class="card-icon">
                        <i class="bi bi-trophy"></i>
                    </div>
                </div>
                <div class="card-value" id="totalReward"></div>
<!--                 <div class="card-description">Achievements unlocked</div>
                <div class="card-trend">
                    <i class="bi bi-arrow-up"></i>
                    <span>{{+3}} this week</span>
                </div> -->
            </div>
        </div>
    </main>

    <!-- Mobile Menu Button -->
   

    <script src="/js/protected/home.js"> </script>
    <script src="/js/protected/homeLoader.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Changer le mot de passe - FidélityApp</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/protected/home.css">
    <link rel="stylesheet" href="/css/protected/changePassword.css">
</head>
<body>
    <!-- Include Sidebar Partial -->
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <main class="main-content" id="mainContent">
        <div class="password-container">
            <!-- Alert Messages -->
            <div id="alertContainer"></div>

            <!-- Page Header -->
            <div class="page-header">
                <button class="back-btn" onclick="history.back()">
                    <i class="bi bi-arrow-left"></i>
                    Retour
                </button>
            </div>

            <!-- Password Change Card -->
            <div class="password-card">
                <!-- Icon -->
                <div class="password-icon">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>

                <!-- Title -->
                <h1 class="password-title">Changer le mot de passe</h1>
                <p class="password-subtitle">
                    Assurez-vous que votre nouveau mot de passe est sécurisé
                </p>

                <!-- Change Password Form -->
                <form id="changePasswordForm">
                    <!-- Current Password -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="bi bi-key"></i>
                            Mot de passe actuel *
                        </label>
                        <div class="password-input-wrapper">
                            <input 
                                type="password" 
                                class="form-input" 
                                id="currentPassword" 
                                name="currentPassword"
                                placeholder="Entrez votre mot de passe actuel"
                                required>
                            <button type="button" class="toggle-password" data-target="currentPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <!-- New Password -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="bi bi-lock"></i>
                            Nouveau mot de passe *
                        </label>
                        <div class="password-input-wrapper">
                            <input 
                                type="password" 
                                class="form-input" 
                                id="newPassword" 
                                name="newPassword"
                                placeholder="Entrez votre nouveau mot de passe"
                                required>
                            <button type="button" class="toggle-password" data-target="newPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        
                        <!-- Password Strength Indicator -->
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bar">
                                <div class="strength-fill" id="strengthFill"></div>
                            </div>
                            <span class="strength-text" id="strengthText">Aucun mot de passe</span>
                        </div>
                    </div>

                    <!-- Confirm New Password -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="bi bi-lock-fill"></i>
                            Confirmer le nouveau mot de passe *
                        </label>
                        <div class="password-input-wrapper">
                            <input 
                                type="password" 
                                class="form-input" 
                                id="confirmPassword" 
                                name="confirmPassword"
                                placeholder="Confirmez votre nouveau mot de passe"
                                required>
                            <button type="button" class="toggle-password" data-target="confirmPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <div class="password-match" id="passwordMatch"></div>
                    </div>

                    <!-- Password Requirements -->
                    <div class="requirements-section">
                        <h3 class="requirements-title">
                            <i class="bi bi-info-circle"></i>
                            Exigences du mot de passe
                        </h3>
                        <ul class="requirements-list" id="requirementsList">
                            <li class="requirement-item" data-requirement="length">
                                <i class="bi bi-circle"></i>
                                <span>Au moins 8 caractères</span>
                            </li>
                            <li class="requirement-item" data-requirement="uppercase">
                                <i class="bi bi-circle"></i>
                                <span>Au moins une lettre majuscule (A-Z)</span>
                            </li>
                            <li class="requirement-item" data-requirement="lowercase">
                                <i class="bi bi-circle"></i>
                                <span>Au moins une lettre minuscule (a-z)</span>
                            </li>
                            <li class="requirement-item" data-requirement="number">
                                <i class="bi bi-circle"></i>
                                <span>Au moins un chiffre (0-9)</span>
                            </li>
                            <li class="requirement-item" data-requirement="special">
                                <i class="bi bi-circle"></i>
                                <span>Au moins un caractère spécial (!@#$%^&*)</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons">
                        <button type="button" class="btn-cancel" id="cancelBtn">
                            <i class="bi bi-x-circle"></i>
                            Annuler
                        </button>
                        <button type="submit" class="btn-submit" id="submitBtn" disabled>
                            <i class="bi bi-check-circle"></i>
                            Changer le mot de passe
                        </button>
                    </div>
                </form>

                <!-- Security Tips -->
                <div class="security-tips">
                    <h4 class="tips-title">
                        <i class="bi bi-shield-check"></i>
                        Conseils de sécurité
                    </h4>
                    <ul class="tips-list">
                        <li>Ne partagez jamais votre mot de passe</li>
                        <li>Utilisez un mot de passe unique pour chaque service</li>
                        <li>Changez votre mot de passe régulièrement</li>
                        <li>Évitez les informations personnelles évidentes</li>
                    </ul>
                </div>
            </div>

            <!-- Success Modal -->
            <div id="successModal" class="modal" style="display: none;">
                <div class="modal-backdrop"></div>
                <div class="modal-content">
                    <div class="modal-icon success">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h2>Mot de passe modifié !</h2>
                    <p>Votre mot de passe a été changé avec succès.</p>
                    <div class="modal-actions">
                        <a href="/profile" class="btn-primary">
                            <i class="bi bi-person"></i>
                            Retour au profil
                        </a>
                        <a href="/" class="btn-secondary">
                            <i class="bi bi-house"></i>
                            Accueil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="/js/protected/home.js"></script>
    <script src="/js/protected/changePassword.js"></script>
</body>
</html>